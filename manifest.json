{
  "manifest_version": 3,
  "name": "DeepSeek Search Pro",
  "version": "2.0.0",
  "description": "Search all your DeepSeek conversations - completely free",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "deepseek-search-pro@example.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["technicalAndInteraction"],
        "optional": []
      }
    }
  }
}